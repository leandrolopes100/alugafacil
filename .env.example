# Copie este arquivo para .env e preencha os valores

DEBUG=True
SECRET_KEY=sua-secret-key-aqui-troque-em-producao

# Hosts permitidos (separados por vírgula, sem espaço)
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Banco de dados ───────────────────────────────────────────────────────────
# SQLite (padrão) — nenhuma configuração necessária em desenvolvimento.
# O arquivo db.sqlite3 é criado automaticamente na raiz do projeto.

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@alugafacil.com.br

# ─── Celery / Redis (opcional — tarefas assíncronas) ─────────────────────────
# Não necessário para rodar o sistema. Deixe em branco se não usar Celery.
REDIS_URL=redis://localhost:6379/0
